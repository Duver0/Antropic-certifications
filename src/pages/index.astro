---
import '../styles/global.css';
import CertCard from '../components/CertCard.astro';
import type { Certificate } from '../types/certificate.ts';

// Import certificates — gracefully handle missing / empty file.
let certificates: Certificate[] = [];
try {
  const data = await import('../../data/certificates.json');
  // data.default is the parsed JSON array
  const raw = data.default as unknown;
  if (Array.isArray(raw)) {
    certificates = raw as Certificate[];
  }
} catch {
  // File missing or malformed — show empty state
  certificates = [];
}

const total = certificates.length;
const lastUpdated = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const logoSrc = `${import.meta.env.BASE_URL}favicon.svg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="All Anthropic Skilljar certificates earned by Duver0."
    />
    <title>My Anthropic Certificates</title>
    <link rel="icon" href={logoSrc} sizes="any" type="image/svg+xml" />
    <link rel="icon" type="image/svg+xml" href={logoSrc} />
    <link rel="shortcut icon" href={logoSrc} type="image/svg+xml" />
  </head>

  <body class="page-shell font-sans text-ink-900">
    <!-- Header -->
    <header class="sticky top-0 z-10 border-b border-[#d9ccb8]/80 bg-[#fffaf1]/90 backdrop-blur-sm">
      <div class="mx-auto flex max-w-6xl items-center gap-4 px-4 py-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3">
          <img
            src={logoSrc}
            alt="Anthropic logo"
            class="h-10 w-10 rounded-xl border border-[#d7c6ad] bg-[#f5ebdb] p-1 object-contain"
          />
          <div>
            <h1 class="hero-title text-2xl leading-none text-ink-900 sm:text-3xl">Anthropic Learning Archive</h1>
            <p class="text-xs tracking-[0.09em] text-ink-500 uppercase">Skilljar Certificates</p>
          </div>
        </div>
        <!-- Count badge -->
        <span
          class="ml-auto inline-flex items-center rounded-full border border-[#d3b79c] bg-[#f4e8d8] px-3 py-1 text-sm font-semibold text-[#8c452b]"
        >
          {total} {total === 1 ? 'certificate' : 'certificates'}
        </span>
      </div>
    </header>

    <!-- Main content -->
    <main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
      <section class="mesh-panel hero-fade-up mb-10 overflow-hidden rounded-3xl border border-[#dac9b2] p-6 shadow-[0_10px_30px_rgba(85,55,38,0.08)] sm:p-8">
        <p class="mb-3 text-xs tracking-[0.11em] text-ink-500 uppercase">Verified Track</p>
        <h2 class="hero-title max-w-3xl text-4xl leading-tight text-ink-900 sm:text-5xl">
          Certificates completed through Anthropic's official learning platform.
        </h2>
        <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ink-700 sm:text-base">
          A curated record of applied coursework and certification progress, refreshed automatically from Skilljar.
        </p>
      </section>

      {total === 0 ? (
        <!-- Empty state -->
        <div class="mesh-panel flex flex-col items-center justify-center gap-4 rounded-3xl border border-[#dac9b2] py-24 text-center">
          <span
            class="grid h-16 w-16 place-items-center rounded-2xl border border-[#d3b79c] bg-[#f4e8d8] text-3xl text-[#9f4f31]"
            aria-hidden="true"
          >🏅</span>
          <h2 class="hero-title text-3xl text-ink-900">No certificates yet</h2>
          <p class="max-w-sm text-ink-500">
            Complete courses on{' '}
            <a
              href="https://anthropic.skilljar.com"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-[#9f4f31] hover:text-[#7a3a24] hover:underline"
            >
              Anthropic Skilljar
            </a>{' '}
            to earn certificates — they'll appear here automatically.
          </p>
        </div>
      ) : (
        <!-- Certificate grid -->
        <div
          class="stagger grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
          aria-label="Certificate grid"
        >
          {certificates.map((cert) => (
            <CertCard cert={cert} />
          ))}
        </div>
      )}
    </main>

    <!-- Footer -->
    <footer class="mt-16 border-t border-[#dbcbb6] bg-[#f5ecde] py-6">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-4 text-xs text-ink-500 sm:flex-row sm:px-6 lg:px-8">
        <span>Last updated: {lastUpdated}</span>
        <a
          href="https://anthropic.skilljar.com"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[#7a3a24] hover:underline"
        >
          anthropic.skilljar.com
        </a>
      </div>
    </footer>
  </body>
</html>
